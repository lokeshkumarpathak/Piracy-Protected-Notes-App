<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_tiled"
    tools:context=".MainActivity">

    <!-- App logo -->
    <ImageView
        android:id="@+id/iv_logo"
        android:layout_width="130dp"
        android:layout_height="130dp"
        android:src="@drawable/logo"
        android:scaleType="centerCrop"
        android:layout_marginTop="32dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Welcome text -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:background="#CCFF90"
        android:text="Welcome Back Learner"
        android:textAlignment="center"
        android:textSize="26sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@+id/iv_logo"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Vertical centre guideline -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.5" />

    <!-- Horizontal mid guideline -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline_mid_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.6" />

    <!-- Row 1, Col 1 — All Notes -->
    <ImageButton
        android:id="@+id/allNotes"
        android:layout_width="185dp"
        android:layout_height="119dp"
        android:layout_margin="12dp"
        android:adjustViewBounds="false"
        android:background="@null"
        android:scaleType="fitXY"
        android:src="@drawable/all_notes_img"
        app:layout_constraintBottom_toTopOf="@+id/guideline_mid_row"
        app:layout_constraintEnd_toStartOf="@+id/guideline_center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <!-- Row 1, Col 2 — Offline Notes -->
    <ImageButton
        android:id="@+id/offlineNotes"
        android:layout_width="185dp"
        android:layout_height="119dp"
        android:layout_margin="12dp"
        android:adjustViewBounds="false"
        android:background="@null"
        android:scaleType="fitXY"
        android:src="@drawable/offline_notes_img"
        app:layout_constraintBottom_toTopOf="@+id/guideline_mid_row"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guideline_center"
        app:layout_constraintTop_toBottomOf="@+id/textView" />

    <!-- Row 2, Col 1 — Saved Screenshots -->

    <!-- Row 2, Col 2 — AI Help -->
    <ImageButton
        android:id="@+id/savedScreenshots"
        android:layout_width="185dp"
        android:layout_height="119dp"
        android:layout_margin="12dp"
        android:adjustViewBounds="false"
        android:background="@null"
        android:scaleType="fitXY"
        android:src="@drawable/saved_screenshots_img"
        app:layout_constraintBottom_toTopOf="@+id/logout"
        app:layout_constraintEnd_toStartOf="@+id/guideline_center"
        app:layout_constraintHorizontal_bias="0.4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/guideline_mid_row"
        app:layout_constraintVertical_bias="0.166" />

    <!-- Logout button pinned to bottom -->
    <ImageButton
        android:id="@+id/aiHelp"
        android:layout_width="185dp"
        android:layout_height="119dp"
        android:layout_margin="12dp"
        android:adjustViewBounds="false"
        android:background="@null"
        android:scaleType="fitXY"
        android:src="@drawable/ai_help_img"
        app:layout_constraintBottom_toTopOf="@+id/logout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guideline_center"
        app:layout_constraintTop_toBottomOf="@+id/guideline_mid_row"
        app:layout_constraintVertical_bias="0.166" />

    <Button
        android:id="@+id/logout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="32dp"
        android:layout_marginEnd="32dp"
        android:layout_marginBottom="24dp"
        android:text="Logout"
        android:textColor="#FFFFFF"
        android:backgroundTint="#C62828"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>