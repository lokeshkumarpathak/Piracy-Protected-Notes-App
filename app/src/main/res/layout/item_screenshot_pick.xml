<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/iv_pick_thumb"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            android:contentDescription="Screenshot" />

        <!-- Selection overlay — visible when selected -->
        <FrameLayout
            android:id="@+id/selection_overlay"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:background="#661565C0"
            android:visibility="gone" />

        <!-- Checkmark badge — visible when selected -->
        <TextView
            android:id="@+id/tv_check"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_gravity="top|end"
            android:layout_margin="6dp"
            android:background="#1565C0"
            android:text="✓"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:gravity="center"
            android:visibility="gone" />

        <!-- Filename label at bottom -->
        <TextView
            android:id="@+id/tv_pick_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="#99000000"
            android:textColor="#FFFFFF"
            android:textSize="10sp"
            android:padding="4dp"
            android:maxLines="1"
            android:ellipsize="end" />

    </FrameLayout>

</androidx.cardview.widget.CardView>