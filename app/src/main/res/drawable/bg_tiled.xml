<?xml version="1.0" encoding="utf-8"?>
<!--
    Tiled background with a semi-transparent white overlay to lighten it.
    Place in res/drawable/bg_tiled.xml

    To adjust lightness:
    - More white (lighter): increase alpha e.g. #CCFFFFFF  (80% white)
    - Less white (darker):  decrease alpha e.g. #55FFFFFF  (33% white)
-->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Layer 1: tiled background image -->
    <item>
        <bitmap
            android:src="@drawable/background"
            android:tileMode="repeat" />
    </item>

    <!-- Layer 2: semi-transparent white overlay — lightens the image -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#AAFFFFFF" />
        </shape>
    </item>

</layer-list>